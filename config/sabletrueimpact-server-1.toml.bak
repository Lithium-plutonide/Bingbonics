#If true, light impacts on grass/podzol/mycelium compress the soil into dirt instead of breaking or ignoring the block. Heavy impacts still break the block normally.
enableSoilCompaction = true
#Minimum impact velocity to trigger soil compaction (grass → dirt). Below this, impacts are too gentle to do anything.
# Default: 3.0
# Range: 0.0 ~ 1000.0
soilCompactionMinVelocity = 3.0
#Impact velocity above which soil compaction is skipped and the block is treated like any other (broken normally). Below this threshold, grass is pressed into dirt instead.
# Default: 14.0
# Range: 0.0 ~ 1000.0
soilCompactionMaxVelocity = 14.0

[general]
	#Master switch for all Sable True Impact behavior.
	enableTrueImpact = true
	#Preset mode. auto applies performancePreset and destructionPreset to the main tuning values at config load. custom leaves every advanced value untouched.
	#Allowed Values: auto, custom
	presetMode = "auto"
	#Global multiplier for impact damage and fracture power.
	# Default: 1.0
	# Range: 0.0 ~ 1000.0
	globalStrengthScale = 1.0
	#Global multiplier for block strength (how much force is needed to start damage).
	# Default: 1.0
	# Range: 0.0 ~ 1000000.0
	globalBlockStrengthScale = 1.0
	#Global multiplier for block toughness (how much energy is absorbed before breaking).
	# Default: 1.0
	# Range: 0.0 ~ 1000000.0
	globalBlockToughnessScale = 1.0
	#Global multiplier for block brittleness (how easily cracks spread).
	# Default: 1.0
	# Range: 0.0 ~ 100.0
	globalBrittlenessScale = 1.0
	#Global multiplier for all block friction values.
	# Default: 1.0
	# Range: 0.0 ~ 10.0
	globalFrictionScale = 1.0
	#Global multiplier for all block restitution (bounciness) values.
	# Default: 1.0
	# Range: 0.0 ~ 2.0
	globalRestitutionScale = 1.0
	#Global multiplier for all block mass values.
	# Default: 1.0
	# Range: 0.0 ~ 100.0
	globalMassScale = 1.0
	#If true, logs detailed material-matchup damage split calculations to the server console.
	enableDebugImpactLogging = false
	#Strength coefficient for block hardness (scaled by hardnessStrengthExponent). Lower than the original 2.0 because the exponent now makes high-hardness materials super-linear.
	# Default: 1.8
	# Range: 0.0 ~ 1000.0
	hardnessStrengthFactor = 1.8
	#Exponent applied to block hardness before multiplying by hardnessStrengthFactor. 1.0 = linear (original). 1.2 makes very hard materials (hardness 50) ~74% stronger relative to stone, without changing soft blocks much.
	# Default: 1.2
	# Range: 0.1 ~ 4.0
	hardnessStrengthExponent = 1.2
	#Strength coefficient per unit of blast^blastStrengthExponent. Lower than the original 5.5 because the exponent now makes high-blast materials scale faster.
	# Default: 4.1
	# Range: 0.0 ~ 1000.0
	blastStrengthFactor = 4.1
	#Exponent applied to blast resistance before multiplying by blastStrengthFactor. 0.5 = sqrt (original). 0.6 makes netherite (blast 6000) roughly twice as strong as with sqrt while keeping stone (blast 6) at the same level.
	# Default: 0.6
	# Range: 0.1 ~ 2.0
	blastStrengthExponent = 0.6
	#How much a block's vanilla explosion resistance contributes to its physical toughness (impact absorption).
	# Default: 0.65
	# Range: 0.0 ~ 1000.0
	blastToughnessFactor = 0.65

	[general.materialMatchup]
		#If true, damage split between colliding materials is determined by their relative impact resistance.
		enableMaterialMatchupDamage = true
		#Controls the severity of the damage split. 1.0 is linear; higher values make strong materials much more resistant to weak materials.
		# Default: 0.85
		# Range: 0.0 ~ 4.0
		materialMatchupExponent = 0.85
		#Extra damage split from toughness ratio. Higher values make tough materials chip less and brittle materials crack more.
		# Default: 0.45
		# Range: 0.0 ~ 4.0
		toughnessMatchupExponent = 0.45
		#If target impact resistance is below this fraction of the moving material's resistance, the moving material takes no fracture damage.
		# Default: 0.25
		# Range: 0.0 ~ 1.0
		selfDamageImmunityRatio = 0.25
		#Repeated weak impacts below this target/self resistance ratio do not accumulate fatigue on the stronger material.
		# Default: 0.55
		# Range: 0.0 ~ 1.0
		strongMaterialFatigueImmunityRatio = 0.55
		#Maximum self damage multiplier when a stronger material hits a noticeably weaker material.
		# Default: 0.015
		# Range: 0.0 ~ 1.0
		strongMaterialSelfDamageCap = 0.015
		#The minimum possible damage multiplier for a strong material hitting a weak material.
		# Default: 0.0
		# Range: 0.0 ~ 1.0
		minSelfDamageScale = 0.0
		#The maximum possible damage multiplier for a weak material hitting a strong material.
		# Default: 3.0
		# Range: 1.0 ~ 100.0
		maxSelfDamageScale = 3.0
		#The minimum possible damage multiplier applied to a target hit by a much weaker structure.
		# Default: 0.25
		# Range: 0.0 ~ 1.0
		minTargetDamageScale = 0.25
		#The maximum possible damage multiplier applied to a weak target hit by a much stronger/tougher structure.
		# Default: 8.0
		# Range: 1.0 ~ 100.0
		maxTargetDamageScale = 8.0

[impact]
	#Impacts below this speed do nothing. Raise this if tiny falls still leave marks.
	# Default: 3.0
	# Range: 0.0 ~ 1000.0
	minEffectVelocity = 3.0
	#Impacts below this speed cannot directly break the hit block.
	# Default: 12.0
	# Range: 0.0 ~ 1000.0
	minBreakVelocity = 12.0
	#Impacts below this speed cannot spread cracks to nearby blocks.
	# Default: 18.0
	# Range: 0.0 ~ 1000.0
	minPropagationVelocity = 18.0
	#Global damage multiplier. Lower is more realistic/conservative, higher is more cinematic.
	# Default: 0.042
	# Range: 0.0 ~ 1000.0
	damageScale = 0.042
	#Velocity exponent for normal block-vs-sublevel impact energy. 2.0 is classic kinetic-energy scaling; higher values make high-speed impacts much more destructive.
	# Default: 2.0
	# Range: 0.0 ~ 8.0
	impactVelocityExponent = 2.0
	#How strongly Sable restitution reduces impact damage. 1.0 means restitution 0.5 roughly halves damage.
	# Default: 1.2
	# Range: 0.0 ~ 10.0
	restitutionDamageReduction = 1.2
	#Elastic blocks require higher speed before they can break or strongly damage other blocks.
	# Default: 6.0
	# Range: 0.0 ~ 20.0
	restitutionBreakVelocityMultiplier = 6.0
	#Elastic blocks below this speed convert impact into reaction motion instead of breaking or damaging terrain.
	# Default: 22.0
	# Range: 0.0 ~ 1000.0
	elasticShatterVelocity = 22.0
	#If false, blocks with Sable restitution never break terrain through True Impact.
	elasticBlocksBreakBlocks = true
	#When terrain is hit, nearby elastic sublevels in this range suppress terrain damage.
	# Default: 8.0
	# Range: 0.0 ~ 128.0
	elasticSubLevelDetectionRange = 8.0
	#Maximum blocks scanned per nearby sublevel to detect elastic materials.
	# Default: 4096
	# Range: 16 ~ 1000000
	elasticSubLevelScanLimit = 4096
	#Safety fallback: if true and elastic blocks cannot break blocks, any nearby sublevel impact is converted to reaction motion instead of block damage. This is broad and disables most sublevel impact damage.
	protectNearbySubLevelImpacts = false
	#How much velocity is returned through Sable's collision callback for elastic blocks.
	# Default: 1.15
	# Range: 0.0 ~ 10.0
	bounceResponseScale = 1.15
	#Restitution above this value gets a bounce response instead of normal damage at moderate speeds.
	# Default: 0.15
	# Range: 0.0 ~ 1.0
	bounceResponseThreshold = 0.15
	#Converts moderate would-be block damage into a counter-motion instead of breaking blocks.
	# Default: 0.75
	# Range: 0.0 ~ 10.0
	reactionResponseScale = 0.75
	#Yield below this value prefers reaction force over block breaking. Raise for less terrain damage.
	# Default: 18.0
	# Range: 0.0 ~ 1000.0
	reactionYieldLimit = 18.0
	#If true, moving Sable physical structures can break or cumulatively damage normal world blocks. Internal sublevel fracture can still split the moving structure either way.
	movingStructuresBreakBlocks = true
	#How strongly low-friction/glancing materials reduce damage.
	# Default: 0.35
	# Range: 0.0 ~ 1.0
	lowFrictionDamageReduction = 0.35
	#Extra damage multiplier for blocks tagged fragile by Sable.
	# Default: 1.75
	# Range: 0.0 ~ 100.0
	fragileDamageMultiplier = 1.75
	#How strongly Sable structure mass affects damage. 1.0 means linear effective mass before the cap.
	# Default: 1.0
	# Range: 0.0 ~ 2.0
	massExponent = 1.0
	#Mass used only when True Impact cannot identify the colliding Sable sublevel. Keep low to avoid tiny objects causing extreme damage.
	# Default: 1.0
	# Range: 0.01 ~ 100000.0
	fallbackImpactMass = 1.0
	#Caps effective mass so huge structures do not erase terrain too easily.
	# Default: 100.0
	# Range: 1.0 ~ 100000.0
	maxEffectiveMass = 100.0
	#Extra strength multiplier for soft blocks like dirt/grass. 1.0 keeps soil softer than wood and stone.
	# Default: 1.0
	# Range: 1.0 ~ 1000.0
	softBlockStrengthMultiplier = 1.0
	#Flat base strength. Keep this low enough that material hardness still matters.
	# Default: 12.0
	# Range: 0.0 ~ 1000.0
	baseStrength = 12.0
	# Default: 1.15
	# Range: 0.0 ~ 1000.0
	crackYieldThreshold = 1.15
	# Default: 9.5
	# Range: 0.0 ~ 1000.0
	breakYieldThreshold = 9.5
	# Default: 16.0
	# Range: 0.0 ~ 1000.0
	heavyBreakYieldThreshold = 16.0
	# Default: 22.0
	# Range: 0.0 ~ 1000.0
	propagationYieldThreshold = 22.0
	enableCracks = true
	enableBlockBreaking = true
	enableCrackPropagation = true

[propagation]
	#Maximum nearby blocks that can receive crack marks from one catastrophic impact.
	# Default: 24
	# Range: 0 ~ 10000
	maxPropagationBlocks = 24
	# Default: 42.0
	# Range: 0.0 ~ 1000000.0
	propagationMinEnergy = 42.0
	# Default: 0.026
	# Range: 0.0 ~ 1000.0
	propagationEnergyScale = 0.026
	# Default: 0.45
	# Range: 0.0 ~ 1.0
	sameBlockDecay = 0.45
	# Default: 0.2
	# Range: 0.0 ~ 1.0
	differentBlockDecay = 0.2
	# Default: 0.75
	# Range: 0.0 ~ 1000.0
	propagationCrackYieldThreshold = 0.75

[pairReaction]
	#Experimental: apply equal-ish counter impulses when two Sable physical sublevels collide and either side is elastic. Disabled by default because Sable's native island solver can reject extra impulses on sleeping collision islands.
	enablePairReaction = false
	#Scales pair collision counter-impulses. Lower if elastic structures launch too hard.
	# Default: 0.025
	# Range: 0.0 ~ 10.0
	pairReactionScale = 0.025
	#Caps raw collision force used by pair reaction.
	# Default: 250.0
	# Range: 0.0 ~ 1000000.0
	pairReactionMaxImpulse = 250.0
	#Caps approximate velocity change from one pair reaction impulse.
	# Default: 3.0
	# Range: 0.0 ~ 1000.0
	pairReactionMaxVelocityChange = 3.0
	#Minimum collision force required to trigger a pair reaction impulse. Prevents micro-jitter and 'bumping' on light touches.
	# Default: 50.0
	# Range: 0.0 ~ 1000000.0
	pairReactionForceThreshold = 50.0

[terrainImpact]
	#Experimental: when a Sable sublevel hits normal terrain, damage the terrain using the sublevel mass even if the callback fires on the sublevel block side.
	enableTerrainImpactDamage = true
	# Default: 1.6E-4
	# Range: 0.0 ~ 1000.0
	terrainImpactDamageScale = 1.6E-4
	#Terrain impacts below this force are treated as rolling/sliding contact and do not damage terrain.
	# Default: 2200.0
	# Range: 0.0 ~ 1.0E9
	terrainImpactForceThreshold = 2200.0
	#Exponent applied to terrain collision force above the threshold. 1.0 keeps current linear force scaling; higher values make violent impacts dig much harder.
	# Default: 1.0
	# Range: 0.0 ~ 8.0
	terrainImpactForceExponent = 1.0
	#Separate mass exponent for terrain damage. Lower than global massExponent so normal vehicles crack terrain before breaking it.
	# Default: 0.7
	# Range: 0.0 ~ 2.0
	terrainImpactMassExponent = 0.7
	#Separate effective mass cap for terrain damage.
	# Default: 35.0
	# Range: 1.0 ~ 100000.0
	terrainImpactMaxEffectiveMass = 35.0
	#Horizontal impacts within this distance below a block top are treated as step-up contact, not terrain damage.
	# Default: 0.22
	# Range: 0.0 ~ 1.0
	terrainStepContactForgiveness = 0.22
	#Contacts with vertical normal component below this are considered side contacts for step forgiveness.
	# Default: 0.35
	# Range: 0.0 ~ 1.0
	terrainStepSideNormalThreshold = 0.35
	# Default: 3.5
	# Range: 0.0 ~ 1000.0
	terrainImpactBreakYield = 3.5
	#Maximum terrain blocks broken by one terrain impact collision.
	# Default: 4
	# Range: 0 ~ 10000
	terrainImpactMaxBlocks = 4
	#Maximum contact points sampled for a flat terrain impact. Higher values reduce corner-only craters at higher CPU cost.
	# Default: 24
	# Range: 1 ~ 10000
	terrainImpactContactSamples = 24

[entityImpact]
	#Damages living entities near a Sable sublevel impact point.
	enableEntityImpactDamage = true
	# Default: 0.18
	# Range: 0.0 ~ 1000.0
	entityImpactDamageScale = 0.18
	# Default: 1.0
	# Range: 0.0 ~ 1000.0
	entityImpactMinDamage = 1.0
	#Maximum damage per entity impact. Set to 0 for unlimited.
	# Default: 18.0
	# Range: 0.0 ~ 1000000.0
	entityImpactMaxDamage = 18.0
	#Radius around the impact point that can damage entities.
	# Default: 1.75
	# Range: 0.0 ~ 32.0
	entityImpactRadius = 1.75
	#Damage scale for direct moving sublevel vs living entity impacts.
	# Default: 0.006
	# Range: 0.0 ~ 1000.0
	entityMovingImpactDamageScale = 0.006
	#Maximum damage for direct moving sublevel vs living entity impacts. Set to 0 for unlimited.
	# Default: 6.0
	# Range: 0.0 ~ 1000000.0
	entityMovingImpactMaxDamage = 6.0
	#Small contact margin for direct moving sublevel entity impacts. This replaces broad radius damage for direct hits.
	# Default: 0.18
	# Range: 0.0 ~ 4.0
	entityMovingImpactContactMargin = 0.18
	#Direct entity impact needs this much relative speed between sublevel and entity.
	# Default: 3.0
	# Range: 0.0 ~ 1000.0
	entityMovingImpactMinRelativeSpeed = 3.0
	#Direct entity impact needs this much speed toward the entity, not merely shared acceleration.
	# Default: 1.75
	# Range: 0.0 ~ 1000.0
	entityMovingImpactMinClosingSpeed = 1.75
	#Entities whose feet are within this distance above a sublevel top are treated as standing on it, not being hit by it.
	# Default: 0.35
	# Range: 0.0 ~ 4.0
	entityStandingSupportTolerance = 0.35
	#Standing support is ignored if the sublevel is moving upward faster than this.
	# Default: 1.25
	# Range: 0.0 ~ 1000.0
	entityStandingMaxUpwardSpeed = 1.25
	#Sublevel speed below this value will not directly damage entities.
	# Default: 4.0
	# Range: 0.0 ~ 1000.0
	entityImpactMinSpeed = 4.0
	#Per entity/sublevel hit cooldown to avoid damage every tick while pinned.
	# Default: 20
	# Range: 0 ~ 200
	entityImpactCooldownTicks = 20

[subLevelFracture]
	#Experimental: very strong impacts can cut weak internal connections so Sable's native splitter creates new sublevels.
	enableSubLevelFracture = true
	#Minimum collision force before internal sublevel fracture is considered. Raise this if vehicles split too easily.
	# Default: 620.0
	# Range: 0.0 ~ 1.0E9
	subLevelFractureForceThreshold = 620.0
	#Minimum relative speed between two Sable physical structures before contact force can cause internal fracture. This filters static support/contact forces.
	# Default: 3.0
	# Range: 0.0 ~ 1000.0
	subLevelFractureMinRelativeSpeed = 3.0
	#Minimum speed along the contact normal before two Sable structures are considered to be crashing into each other.
	# Default: 1.5
	# Range: 0.0 ~ 1000.0
	subLevelFractureMinClosingSpeed = 1.5
	#Damage scale for high-force but low-speed static contacts. 0 disables static pressure fracture in the impact model.
	# Default: 0.0
	# Range: 0.0 ~ 1000.0
	subLevelFractureStaticForceDamageScale = 0.0
	#Scales raw collision force into fracture damage.
	# Default: 0.068
	# Range: 0.0 ~ 1000.0
	subLevelFractureForceScale = 0.068
	#Exponent applied to collision force above the fracture threshold. 1.0 keeps current linear behavior; higher values make high-speed/high-force crashes split structures much more aggressively.
	# Default: 1.0
	# Range: 0.0 ~ 8.0
	subLevelFractureForceExponent = 1.0
	#Maximum radius around the impact point scanned for weak connections.
	# Default: 4.0
	# Range: 0.0 ~ 32.0
	subLevelFractureRadius = 4.0
	#Maximum internal blocks removed by one fracture event.
	# Default: 18
	# Range: 0 ~ 10000
	subLevelFractureMaxBlocks = 18
	#Maximum block positions inspected by one fracture scan. Lower this to cap worst-case CPU cost.
	# Default: 384
	# Range: 1 ~ 1000000
	subLevelFractureMaxCandidateChecks = 384
	#Maximum fracture candidates kept for sorting and chance checks. Lower this if impacts stutter when many blocks are nearby.
	# Default: 96
	# Range: 1 ~ 1000000
	subLevelFractureMaxCandidates = 96
	#Extra block padding captured around fracture candidates for structural analysis. 1 is faster, 2 is more detailed.
	# Default: 1
	# Range: 0 ~ 4
	subLevelFractureSnapshotPadding = 1
	#High-friction blocks resist fracture by this multiplier per friction point.
	# Default: 1.6
	# Range: 0.0 ~ 1000.0
	subLevelFractureFrictionResistance = 1.6
	#Same-material connections resist fracture more than mixed-material seams.
	# Default: 1.6
	# Range: 0.0 ~ 1000.0
	subLevelFractureSameBlockResistance = 1.6
	#Resistance multiplier for sticky/glue-like blocks. Large values make them almost never fracture.
	# Default: 10000.0
	# Range: 1.0 ~ 1.0E9
	subLevelFractureStickyResistance = 10000.0
	#Mass at which a structure starts receiving noticeable extra fracture power.
	# Default: 14.0
	# Range: 1.0 ~ 1000000.0
	subLevelFractureMassReference = 14.0
	#How much large structures amplify fracture power.
	# Default: 0.8
	# Range: 0.0 ~ 1000.0
	subLevelFractureMassBonusScale = 0.8
	#How much off-center impacts amplify fracture power.
	# Default: 0.85
	# Range: 0.0 ~ 1000.0
	subLevelFractureImbalanceBonusScale = 0.85
	#Maximum multiplier from off-center mass imbalance.
	# Default: 4.0
	# Range: 1.0 ~ 1000.0
	subLevelFractureImbalanceMaxMultiplier = 4.0
	#Converts fracture score into actual break chance. Raise for more random/local breakage.
	# Default: 1.25
	# Range: 0.0 ~ 1000.0
	subLevelFractureChanceScale = 1.25
	#Higher values concentrate fracture probability near the impact point.
	# Default: 1.8
	# Range: 0.1 ~ 10.0
	subLevelFractureImpactFocusExponent = 1.8
	#How much existing cumulative crack damage increases fracture chance.
	# Default: 3.0
	# Range: 0.0 ~ 1000.0
	subLevelFractureCrackBonusScale = 3.0
	#How much near-miss fracture force is stored as cumulative block damage/cracks.
	# Default: 0.22
	# Range: 0.0 ~ 1000.0
	subLevelFractureFatigueScale = 0.22
	#Strength multiplier from checkerboard/interlocked mixed-material neighbors.
	# Default: 1.8
	# Range: 0.0 ~ 1000.0
	subLevelFractureInterlockStrength = 1.8
	#Strength multiplier from beam/girder/frame/support blocks near a candidate fracture.
	# Default: 2.4
	# Range: 0.0 ~ 1000.0
	subLevelFractureBeamStrength = 2.4
	#Extra weakness for straight continuous seams. Interlocked seams resist this.
	# Default: 1.7
	# Range: 0.0 ~ 1000.0
	subLevelFractureContinuousSeamWeakness = 1.7
	#How much likely fracture planes increase fracture chance in nearby aligned blocks.
	# Default: 0.55
	# Range: 0.0 ~ 1000.0
	subLevelFractureWeakPlaneSpread = 0.55

[explosionImpact]
	#If true, explosions send pressure waves into nearby Sable physical structures, causing cracks and internal fracture.
	enableExplosionImpactFracture = true
	#Scales explosion radius and distance into fracture force. Raise for more dramatic blast separation.
	# Default: 225.0
	# Range: 0.0 ~ 1000000.0
	explosionImpactForceScale = 225.0
	#How far explosions search for Sable physical structures, as a multiplier of explosion radius.
	# Default: 1.65
	# Range: 0.0 ~ 32.0
	explosionImpactRadiusMultiplier = 1.65
	#Extra blast pressure in enclosed spaces (blockedRatio^2). Higher values make indoor explosions much more lethal than outdoor ones.
	# Default: 4.5
	# Range: 0.0 ~ 100.0
	explosionImpactConfinementScale = 4.5
	#Maximum nearby Sable physical structures processed by one explosion.
	# Default: 32
	# Range: 1 ~ 1000000
	explosionImpactMaxSubLevels = 32
	#Invisible shockwave ray count used to detect enclosed blasts and impacted Sable structures. Higher is more accurate but costs more CPU.
	# Default: 48
	# Range: 6 ~ 512
	explosionImpactRaySamples = 48
	#Distance advanced per shockwave ray sample step. Lower is more precise but costs more CPU.
	# Default: 0.75
	# Range: 0.1 ~ 4.0
	explosionImpactRayStep = 0.75
	#If true, shockwave hits push Sable physical structures away from the explosion center.
	enableExplosionImpulse = true
	#Converts shockwave pressure into outward impulse. Raise for more dramatic flying debris.
	# Default: 0.018
	# Range: 0.0 ~ 1000.0
	explosionImpulseScale = 0.018
	#Caps outward impulse from one explosion hit per Sable physical structure.
	# Default: 80.0
	# Range: 0.0 ~ 1000000.0
	explosionMaxImpulse = 80.0

[impactExplosion]
	#If true, massive high-energy crashes can trigger standard Minecraft explosions at the impact point.
	enableImpactExplosions = false
	#Minimum collision force (before mass scaling) to trigger an impact explosion.
	# Default: 5000.0
	# Range: 0.0 ~ 1.0E9
	impactExplosionForceThreshold = 5000.0
	#Minimum Sable structure mass required to trigger an impact explosion.
	# Default: 15.0
	# Range: 0.0 ~ 1000000.0
	impactExplosionMassThreshold = 15.0
	#Scales total impact energy (force * mass) into explosion radius.
	# Default: 1.8E-5
	# Range: 0.0 ~ 100.0
	impactExplosionScale = 1.8E-5
	#Caps the radius of impact-triggered explosions.
	# Default: 12.0
	# Range: 0.0 ~ 64.0
	impactExplosionMaxRadius = 12.0
	#Chance (0.0 to 1.0) that an impact explosion creates fire. 0.0 disables fire entirely.
	# Default: 0.0
	# Range: 0.0 ~ 1.0
	impactExplosionFireChance = 0.0
	#Maximum number of explosions that can fire from a single collision batch. Prevents a crash from spawning dozens of simultaneous explosion sound sources and freezing physics-audio mods.
	# Default: 1
	# Range: 1 ~ 64
	impactExplosionMaxPerBatch = 1
	#Explosions within this distance (blocks) of a stronger explosion in the same batch are suppressed. Keeps one big boom instead of many small ones.
	# Default: 16.0
	# Range: 0.0 ~ 256.0
	impactExplosionCoalesceRadius = 16.0

[materialToughness]
	#If true, selected materials receive separate strength, toughness, and brittleness multipliers.
	enableMaterialToughness = true
	#Scale for how much explosion resistance reduces a material's brittleness. High blast resistance makes materials more 'ductile'.
	# Default: 0.01
	# Range: 0.0 ~ 1.0
	blastBrittlenessDecay = 0.01

[cumulativeDamage]
	#Accumulates repeated crack-level hits until the block breaks.
	enableCumulativeBlockDamage = true
	# Default: 0.65
	# Range: 0.0 ~ 1000.0
	cumulativeBlockDamageScale = 0.65
	#Per-hit cumulative damage below this fraction of the break threshold is ignored. This prevents hard blocks from being sanded down by tiny weak impacts.
	# Default: 0.035
	# Range: 0.0 ~ 1.0
	minCumulativeDamageRatio = 0.035
	#Ticks before stored block damage expires if the block is not hit again.
	# Default: 600
	# Range: 20 ~ 72000
	cumulativeBlockDamageDecayTicks = 600
	#Safety cap for remembered damaged blocks.
	# Default: 4096
	# Range: 128 ~ 1000000
	cumulativeBlockDamageMaxEntries = 4096

[performance]
	#Performance budget preset. Applied on config load when presetMode is auto. This has priority over destructionPreset when both affect cost.
	#Allowed Values: potato, very_low, low, medium, high, very_high, destructive
	performancePreset = "low"
	#Destruction detail preset. Applied on config load when presetMode is auto. Higher values enable more detailed cracks, fracture, explosions, and material response.
	#Allowed Values: off, low, medium, high, cinematic
	destructionPreset = "medium"
	#If true, logs periodic Sable True Impact performance counters. Keep false for normal gameplay.
	enablePerformanceLogging = false
	#How often performance counters are logged when enablePerformanceLogging is true.
	# Default: 200
	# Range: 20 ~ 72000
	performanceLogIntervalTicks = 200

	[performance.limits]
		#How often direct moving sublevel entity damage scans run. 1 = every tick, 2 = every other tick. Raise for better server performance.
		# Default: 2
		# Range: 1 ~ 200
		entityImpactScanIntervalTicks = 2
		#Maximum moving Sable sublevels checked for direct entity damage per scan. Lower this if worlds with many physical structures stutter.
		# Default: 96
		# Range: 1 ~ 1000000
		entityImpactMaxSubLevelsPerScan = 96
		#Minimum ticks between expensive fracture scans for the same Sable physical structure. Raise this for large-structure performance.
		# Default: 4
		# Range: 0 ~ 200
		subLevelFractureCooldownTicks = 4
		#Global cap for fracture scans started per server tick per dimension. Extra collision points skip fracture to protect TPS.
		# Default: 8
		# Range: 1 ~ 1000000
		subLevelFractureMaxAttemptsPerTick = 8
		#Experimental: compute fracture candidates on a background thread after the world snapshot is captured on the server thread. Final block changes still run on the server thread.
		enableAsyncFractureAnalysis = false
		#Maximum pending async fracture jobs. New async jobs are skipped when the queue is full to protect server TPS.
		# Default: 64
		# Range: 1 ~ 1000000
		asyncFractureMaxQueuedJobs = 64
		#Maximum completed async fracture jobs applied to the world per tick.
		# Default: 4
		# Range: 1 ~ 10000
		asyncFractureMaxAppliedJobsPerTick = 4

[customization]
	#If true, Sable True Impact attaches its collision callback while Sable builds voxel collider data. This avoids making every Block implement Sable's callback interface.
	enableUniversalImpactCallback = true
	#Controls callback selection. 'blacklist' applies True Impact to all blocks except impactCallbackBlockBlacklist. 'whitelist' applies only to impactCallbackBlocks.
	impactCallbackMode = "blacklist"
	#Blocks that receive the True Impact callback when impactCallbackMode is 'whitelist'.
	impactCallbackBlocks = []
	#Blocks that never receive the universal True Impact callback. Sable's own callbacks are still preserved. Keep Create functional blocks here if another mod changes their interaction behavior.
	impactCallbackBlockBlacklist = ["create:blaze_burner"]
	#List of custom block physical properties overrides. Format: 'modid:blockid,strength,toughness,friction,elasticity,mass,destructible'. Example: 'minecraft:obsidian,6.0,8.0,0.5,0.2,50.0,true'
	customBlockProperties = []
	#Global toggle for internal physical structure destruction (SubLevel Fracture).
	enablePhysicalDestruction = true
	#Global toggle for world block destruction (Terrain/Blocks hit by physical structures).
	enableWorldDestruction = true
	#Explicit list of block IDs or tags to mark as destructible (true) or indestructible (false). Format: 'modid:blockid,true' or 'tag:modid:tagname,false'. Overrides other settings.
	destructibleOverrides = []

[createContraptionAnchors]
	#If true, impacts near Create contraption anchors transfer part of the load to bearings, pistons, pulleys, car assemblers, and nearby support blocks.
	enableCreateContraptionAnchorDamage = true
	#If true, nearby Create moving contraptions are scanned as a whole; overloads above their estimated structural capacity amplify anchor damage.
	enableCreateContraptionLoadFailure = true
	#Damage scale for Create contraption anchor load transfer.
	# Default: 1.0
	# Range: 0.0 ~ 1000.0
	createContraptionAnchorDamageScale = 1.0
	#Radius around an impact point to search for Create contraption anchors that should receive transferred impact load.
	# Default: 4
	# Range: 0 ~ 16
	createContraptionAnchorDamageRadius = 4
	#Radius around an impact point to search for Create moving contraption entities.
	# Default: 8.0
	# Range: 1.0 ~ 128.0
	createContraptionLoadScanRange = 8.0
	#Maximum Create contraption blocks scanned when estimating whole-structure load capacity.
	# Default: 4096
	# Range: 16 ~ 1000000
	createContraptionLoadScanLimit = 4096
	#Scales estimated whole-contraption structural capacity. Higher values make Create contraptions harder to overload.
	# Default: 1.0
	# Range: 0.0 ~ 1000000.0
	createContraptionLoadCapacityScale = 1.0
	#Impact load must exceed estimated capacity times this factor before anchor overload damage is amplified.
	# Default: 1.0
	# Range: 0.01 ~ 1000.0
	createContraptionLoadSafetyFactor = 1.0
	#Additional anchor damage multiplier applied when a Create contraption exceeds whole-structure load capacity.
	# Default: 2.5
	# Range: 0.0 ~ 1000.0
	createContraptionOverloadAnchorDamageScale = 2.5
